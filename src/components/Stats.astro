---
// Stats.astro
// Key metrics section — Dark Glass Fluid Theme
---

<section id="stats" class="section-light">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item glass-card">
        <div class="stat-number">40</div>
        <div class="stat-label">Workflows</div>
      </div>
      <div class="stat-item glass-card">
        <div class="stat-number">229+</div>
        <div class="stat-label">Skills</div>
      </div>
      <div class="stat-item glass-card">
        <div class="stat-number">8</div>
        <div class="stat-label">Agents</div>
      </div>
      <div class="stat-item glass-card">
        <div class="stat-number">6</div>
        <div class="stat-label">Guards</div>
      </div>
      <div class="stat-item glass-card">
        <div class="stat-number">307</div>
        <div class="stat-label">Tests</div>
      </div>
    </div>
    <p class="stats-footer">
      98 TypeScript modules · 6 design patterns · 100% type coverage
    </p>
  </div>
</section>

<style>
#stats {
  padding: var(--space-3xl) 0;
  position: relative;
}

.stats-grid {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

.stat-item {
  text-align: center;
  padding: 20px 24px;
  border-radius: 12px;
  min-width: 140px;
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.07);
}

.stat-number {
  font-size: clamp(34px, 5vw, 52px);
  font-weight: 600;
  color: rgba(255, 255, 255, 1);
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 8px;
}

.stat-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 0.04em;
  font-weight: 500;
}

.stats-footer {
  text-align: center;
  font-size: 14px;
  color: var(--text-tertiary);
  padding: 16px 24px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-md);
  max-width: 500px;
  margin: 0 auto;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

@media (max-width: 768px) {
  .stats-grid {
    gap: 16px;
  }

  .stat-item {
    padding: 20px 22px;
    min-width: 120px;
  }

  .stat-number {
    font-size: 36px;
  }
}

@media (max-width: 480px) {
  .stats-grid {
    gap: 12px;
  }

  .stat-item {
    padding: 20px 16px;
    min-width: 100px;
    flex: 1 1 40%;
  }
}
</style>
