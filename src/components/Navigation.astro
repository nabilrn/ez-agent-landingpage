---
// Navigation.astro — transparent on hero, glass after scroll
const REPO = 'howlil/ez-agents';
const homePath = import.meta.env.BASE_URL;
const docsPath = `${import.meta.env.BASE_URL}docs`;

let stars: string | null = null;
try {
  const res = await fetch(`https://api.github.com/repos/${REPO}`, {
    headers: { 'User-Agent': 'ez-agents-site' },
  });
  if (res.ok) {
    const data = await res.json();
    const count = data.stargazers_count ?? 0;
    stars = count >= 1000
      ? `${(count / 1000).toFixed(1)}k`
      : `${count}`;
  }
} catch {
  stars = null;
}
---

<nav id="main-nav" data-scrolled="false">
  <a href={homePath} class="logo">EZ AGENTS</a>
  <div class="nav-links">
    <a href={docsPath} target="_blank" rel="noopener">Docs</a>
    <a
      href={`https://github.com/${REPO}`}
      target="_blank"
      rel="noopener"
      class="github-link"
      aria-label="View on GitHub"
    >
      <svg
        class="github-icon"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.26.82-.577 0-.286-.011-1.04-.017-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.082-.73.082-.73 1.205.085 1.838 1.237 1.838 1.237 1.07 1.835 2.81 1.305 3.495.998.108-.776.42-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.468-2.382 1.236-3.222-.124-.303-.535-1.524.117-3.176 0 0 1.008-.323 3.3 1.23A11.5 11.5 0 0 1 12 5.8c1.02.005 2.047.138 3.006.404 2.29-1.553 3.297-1.23 3.297-1.23.654 1.652.243 2.873.12 3.176.77.84 1.235 1.912 1.235 3.222 0 4.61-2.807 5.62-5.48 5.92.43.37.815 1.103.815 2.222 0 1.604-.015 2.898-.015 3.293 0 .32.218.694.825.576C20.565 21.795 24 17.297 24 12c0-6.63-5.37-12-12-12Z"/>
      </svg>
      <span class="github-label">GitHub</span>
      {stars && (
        <span class="star-pill">
          <svg
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
          <span>{stars}</span>
        </span>
      )}
    </a>
  </div>
</nav>

<style>
#main-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 32px;
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: 1px solid transparent;
  box-shadow: none;
  transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, padding 0.3s ease;
}

#main-nav[data-scrolled="true"] {
  background: rgba(8, 8, 8, 0.72);
  backdrop-filter: var(--glass-blur) saturate(160%);
  -webkit-backdrop-filter: var(--glass-blur) saturate(160%);
  border-bottom-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 10px 36px rgba(0, 0, 0, 0.46);
  padding: 12px 32px;
}

.logo {
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0.05em;
  text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
}

.nav-links {
  display: flex;
  gap: 20px;
  align-items: center;
}

.nav-links > a {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
  transition: color 0.25s ease;
  text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
}

.nav-links > a:hover {
  color: rgba(255, 255, 255, 0.95);
}

.github-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px 6px 12px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
}

.github-link:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.22);
}

.github-icon {
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.85);
}

.github-label {
  font-size: 13px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.star-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--accent-gold);
  background: rgba(200, 169, 114, 0.1);
  border: 1px solid rgba(200, 169, 114, 0.25);
  padding: 2px 8px;
  border-radius: 999px;
  line-height: 1;
}

.star-pill svg {
  flex-shrink: 0;
}

@media (max-width: 768px) {
  #main-nav {
    padding: 12px 16px;
  }

  #main-nav[data-scrolled="true"] {
    padding: 10px 16px;
  }

  .nav-links {
    gap: 12px;
  }

  .nav-links > a {
    font-size: 13px;
  }

  .github-label {
    display: none;
  }

  .github-link {
    padding: 6px 10px;
  }
}
</style>

<script>
(function () {
  const nav = document.getElementById('main-nav');
  if (!nav) return;

  const THRESHOLD = 24;
  const update = () => {
    const scrolled = window.scrollY > THRESHOLD;
    nav.dataset.scrolled = scrolled ? 'true' : 'false';
  };

  update();
  window.addEventListener('scroll', update, { passive: true });
})();
</script>
